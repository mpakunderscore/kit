{
    "name": "kit.mpak.space",
    "version": "0.0.3",
    "description": "kit",
    "type": "module",
    "scripts": {
        "start": "node dist/server/server.cjs",
        "build": "npm run build:server && npm run build:client",
        "build:server": "vite build --config config/build/vite.server.config.ts",
        "build:client": "vite build --config config/build/vite.client.config.ts",
        "dev:server": "tsx watch server/server.ts",
        "dev:client": "vite --config config/build/vite.client.config.ts",
        "lint": "npm run lint:format && npm run lint:js && npm run lint:css",
        "lint:format": "prettier --config config/lint/.prettierrc --write . --ignore-path config/lint/.prettierignore",
        "lint:js": "eslint --config config/lint/eslint.config.mjs src server --fix",
        "lint:css": "npx stylelint \"src/**/*.css\" --fix --config config/lint/stylelint.config.cjs --ignore-path config/lint/.stylelintignore",
        "check": "npm run typecheck && npm run lint && npm run build",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "deps:updates": "npx npm-check-updates -u",
        "prisma:generate": "prisma generate --config config/db/prisma.config.ts",
        "prisma:validate": "prisma validate --config config/db/prisma.config.ts",
        "prisma:migrate:dev": "prisma migrate dev --config config/db/prisma.config.ts",
        "prisma:migrate:deploy": "prisma migrate deploy --config config/db/prisma.config.ts",
        "prisma:db:push": "prisma db push --config config/db/prisma.config.ts",
        "prisma:studio": "prisma studio --config config/db/prisma.config.ts"
    },
    "author": "mpakunderscore",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "better-sqlite3": "^12.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "5.2.1",
        "lucide-react": "^1.8.0",
        "prisma": "^7.7.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^4.2.3",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@webgpu/types": "^0.1.69",
        "eslint": "^10.2.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.2",
        "prettier-plugin-css-order": "^2.2.0",
        "stylelint": "^17.6.0",
        "stylelint-config-standard": "^40.0.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.8"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
