{
    "name": "kit",
    "version": "0.0.7",
    "description": "kit",
    "main": "dist/electron/main.js",
    "type": "module",
    "scripts": {
        "start": "node dist/server/server.cjs",
        "build": "npm run build:server && npm run build:client",
        "build:server": "vite build --config config/build/vite.server.config.ts",
        "build:client": "vite build --config config/build/vite.client.config.ts",
        "dev:server": "tsx watch server/server.ts",
        "dev:client": "vite --config config/build/vite.client.config.ts",
        "lint": "npm run lint:format && npm run lint:js && npm run lint:css",
        "lint:format": "prettier --config config/lint/.prettierrc --write . --ignore-path config/lint/.prettierignore",
        "lint:js": "eslint --config config/lint/eslint.config.mjs src server electron --max-warnings 0 --fix",
        "lint:css": "npx stylelint \"src/**/*.css\" --fix --config config/lint/stylelint.config.cjs --ignore-path config/lint/.stylelintignore",
        "check": "npm run typecheck && npm run lint && npm run build",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "deps:updates": "npx npm-check-updates -u",
        "prisma:server:generate": "prisma generate --config config/db/prisma.server.config.ts",
        "prisma:server:validate": "prisma validate --config config/db/prisma.server.config.ts",
        "prisma:server:migrate:dev": "prisma migrate dev --config config/db/prisma.server.config.ts",
        "prisma:server:migrate:deploy": "prisma migrate deploy --config config/db/prisma.server.config.ts",
        "prisma:server:db:push": "prisma db push --config config/db/prisma.server.config.ts",
        "prisma:server:studio": "prisma studio --config config/db/prisma.server.config.ts",
        "cap:copy:android": "cap copy android",
        "cap:copy:ios": "cap copy ios",
        "cap:sync:android": "npm run build:client && cap sync android",
        "cap:sync:ios": "npm run build:client && cap sync ios",
        "electron:build:ts": "tsc -p config/build/tsconfig.electron.json && node config/build/writeElectronPackageJson.cjs",
        "electron:build:desktop": "npm run electron:build:ts && npm run electron:rebuild && electron-builder",
        "electron:dev": "npm run electron:build:ts && npm run electron:rebuild && npm run electron:dev:run",
        "electron:dev:run": "wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist/electron/main.js",
        "electron:start": "cross-env NODE_ENV=production electron dist/electron/main.js",
        "electron:rebuild": "electron-builder install-app-deps",
        "prisma:app:generate": "prisma generate --config config/db/prisma.app.config.ts",
        "prisma:app:migrate:dev": "prisma migrate dev --config config/db/prisma.app.config.ts",
        "prisma:app:migrate:deploy": "prisma migrate deploy --config config/db/prisma.app.config.ts",
        "prisma:app:db:push": "prisma db push --config config/db/prisma.app.config.ts",
        "prisma:app:studio": "prisma studio --config config/db/prisma.app.config.ts"
    },
    "author": "mpakunderscore",
    "license": "ISC",
    "dependencies": {
        "@capacitor/android": "^8.3.0",
        "@capacitor/core": "^8.3.0",
        "@capacitor/ios": "^8.3.0",
        "@prisma/adapter-better-sqlite3": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "better-sqlite3": "^12.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.1",
        "express": "5.2.1",
        "lucide-react": "^1.8.0",
        "prisma": "^6.19.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.3.0",
        "@electron/rebuild": "^4.0.3",
        "@eslint-react/eslint-plugin": "^4.2.3",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@webgpu/types": "^0.1.69",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "eslint": "^10.2.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.2",
        "prettier-plugin-css-order": "^2.2.0",
        "stylelint": "^17.6.0",
        "stylelint-config-standard": "^40.0.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.8",
        "wait-on": "^9.0.5"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "build": {
        "appId": "space.mpak.kit",
        "productName": "KIT",
        "directories": {
            "output": "dist/release"
        },
        "files": [
            "dist/electron/**",
            "dist/client/**"
        ],
        "mac": {
            "icon": "public/icons/icon.icns",
            "category": "public.app-category.utilities"
        }
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
