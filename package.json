{
    "name": "kit.mpak.space",
    "version": "0.0.1",
    "description": "kit",
    "type": "module",
    "scripts": {
        "build": "npm run build:server && npm run build:client",
        "build:server": "tsc -p config/tsconfig.server.json",
        "build:client": "vite build --config config/vite.config.ts",
        "dev:server": "tsx watch server/server.ts",
        "dev:client": "vite --config config/vite.config.ts",
        "lint": "npm run lint:format && npm run lint:js && npm run lint:css",
        "lint:format": "prettier --config config/.prettierrc --write . --ignore-path config/.prettierignore",
        "lint:js": "eslint --config config/eslint.config.mjs src --fix",
        "lint:css": "npx stylelint \"src/**/*.css\" --fix --config config/stylelint.config.cjs --ignore-path config/.stylelintignore",
        "deps:updates": "npx npm-check-updates -u",
        "typecheck": "npm run typecheck:server && npm run typecheck:client",
        "typecheck:server": "tsc -p config/tsconfig.server.json --noEmit",
        "typecheck:client": "tsc -p config/tsconfig.client.json --noEmit"
    },
    "author": "mpakunderscore",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.6.0",
        "@prisma/client": "^7.6.0",
        "better-sqlite3": "^12.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "5.2.1",
        "lucide-react": "^1.7.0",
        "prisma": "^7.6.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^4.2.3",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@webgpu/types": "^0.1.69",
        "eslint": "^10.2.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-css-order": "^2.2.0",
        "stylelint": "^17.6.0",
        "stylelint-config-standard": "^40.0.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
