{
    "compilerOptions": {
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strictPropertyInitialization": true,
        "useDefineForClassFields": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@src/*": ["src/*"],
            "@server/*": ["server/*"],
            "@electron/*": ["electron/*"]
        },
        "sourceMap": true,
        "noImplicitAny": true,
        "jsx": "react-jsx",
        "allowJs": false,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "ignoreDeprecations": "6.0",
        // Ionic/Stencil typings occasionally conflict across versions; we don't want lib .d.ts to block app development.
        "skipLibCheck": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "vite/client"]
    },
    "include": [
        "src/**/*",
        "server/**/*",
        "test/**/*",
        "capacitor.config.ts",
        "config/build/vitest.config.ts"
    ]
}
