{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "../..",
        "paths": {
            "@src/*": ["src/*"],
            "@electron/*": ["electron/*"]
        },
        "rootDir": "../..",
        "outDir": "../../dist",
        "module": "CommonJS",
        "moduleResolution": "node",
        "noEmit": false,
        "lib": ["ES2022", "DOM"],
        "types": ["node", "electron", "better-sqlite3"],
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true
    },
    "include": ["../../electron/**/*.ts"],
    "exclude": ["../../node_modules", "../../dist", "../../server"]
}
