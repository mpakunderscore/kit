{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "../..",
        "outDir": "../../dist/client",
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client", "node", "@webgpu/types"],
        "skipLibCheck": true
    },
    "include": ["../../src/**/*.ts", "../../src/**/*.tsx", "../../src/**/*.d.ts"],
    "exclude": ["../../server/**/*", "../../node_modules", "../../dist", "../../dist-server"]
}
