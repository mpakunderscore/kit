# Template: copy to `.env` in the repository root — that file is the only runtime source.
#
# Build + runtime (used by webpack configs and server/services/autotiling.ts)
NODE_ENV=development

# HTTP server (server/server.ts)
PORT=1000

# Logging (server/utils/logger.ts)
LOG_LEVEL=trace
LOG_FORMAT=text

# Server database (prisma/server.prisma)
DATABASE_URL="file:./data/main.db"

# App local database — Electron dev path (prisma/app.prisma)
APP_DATABASE_URL="file:./data/app.db"
